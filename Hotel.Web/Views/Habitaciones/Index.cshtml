@{
    var activeTab =
        Context.Request.Query["tab"]
        .ToString();

    if (string.IsNullOrEmpty(activeTab))
    {
        activeTab = "recepcion";
    }
}

@model IEnumerable<Hotel.Domain.Entities.Habitacion>

@{
    ViewData["Title"] = "Habitaciones";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>

    body {
    background-color: #f4f6f9;
    }

    .room-card {
    border-radius: 15px;
    cursor: pointer;
    transition: 0.3s;
    }

    .room-card:hover {
    transform: scale(1.03);
    }

    .estado {
    font-size: 18px;
    font-weight: bold;
    }

    .btn-editar {
    background-color: #FFD700;
    border-color: #FFD700;
    color: white;
    }

    .btn-editar:hover {
    background-color: #FFC107;
    border-color: #FFC107;
    color: white;
    }

    .btn-eliminar {
    background-color: #DC3545;
    border-color: #DC3545;
    color: white;
    }

    .btn-eliminar:hover {
    background-color: #C82333;
    border-color: #C82333;
    color: white;
    }

</style>

<div class="container mt-4">

    
    <ul class="nav nav-pills mb-4"
        id="habitacionesTabs">

        <li class="nav-item">

            <button class="nav-link
                @(activeTab == "recepcion"
                        ? "active"
                        : "")"
                    data-bs-toggle="tab"
                    data-bs-target="#recepcion">

                Recepción

            </button>

        </li>

        <li class="nav-item">

            <button class="nav-link
                @(activeTab == "administracion"
                        ? "active"
                        : "")"
                    data-bs-toggle="tab"
                    data-bs-target="#administracion">

                Administración

            </button>

        </li>

    </ul>

    <div class="tab-content">

        @await Html.PartialAsync(
            "Partials/_Recepcion",
            Model)

        @await Html.PartialAsync(
            "Partials/_Administracion",
            Model)

    </div>
    
    </div>

    @await Html.PartialAsync("Partials/_ModalHospedaje")

    @await Html.PartialAsync("Partials/_ModalDetalleHospedaje")

    @await Html.PartialAsync("Partials/_ModalNuevaHabitacion")

    @await Html.PartialAsync("Partials/_ModalEditarHabitacion")

    @await Html.PartialAsync("Partials/_ModalTiposHabitacion")


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/habitaciones/pagos.js"></script>

<script src="~/js/habitaciones/hospedajes.js"></script>

<script src="~/js/habitaciones/tiposHabitacion.js"></script>

<script src="~/js/habitaciones/habitaciones.js"></script>

    @if (TempData["success"] != null)
    {
        <script>

            Swal.fire({
            icon:'success',
            title:'Éxito',
            text:'@TempData["success"]'
            });

        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>

            Swal.fire({
            icon:'error',
            title:'Error',
            text:'@TempData["error"]'
            });

        </script>
    }