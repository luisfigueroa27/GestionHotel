@model IEnumerable<TipoHabitacion>

<ul class="list-group">

    @foreach (var tipo in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">

            <span data-id="@tipo.IdTipoHabitacion">
                @tipo.Nombre
            </span>

            <div>

                <button class="btn btn-warning btn-sm"
                        onclick="editarTipoHabitacion(@tipo.IdTipoHabitacion,'@tipo.Nombre')">

                    Editar

                </button>

                <button class="btn btn-danger btn-sm"
                        onclick="eliminarTipoHabitacion(@tipo.IdTipoHabitacion)">

                    Eliminar

                </button>

            </div>

        </li>
    }

</ul>