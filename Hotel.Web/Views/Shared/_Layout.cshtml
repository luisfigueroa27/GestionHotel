@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Hotel</title>

    <!-- BOOTSTRAP -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- BOOTSTRAP ICONS -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- SWEETALERT -->

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>

        body {
        margin: 0;
        background: #f4f6f9;
        font-family: Arial;
        }

        .wrapper {
        display: flex;
        }

        /* SIDEBAR */

        .sidebar {
        width: 250px;
        min-height: 100vh;
        background: linear-gradient(to bottom,#111,#2c2c2c);
        color: white;
        }

        .logo {
        padding: 20px;
        font-size: 28px;
        text-align: center;
        border-bottom: 1px solid #444;
        }

        .menu {
        padding-top: 20px;
        }

        .menu a {
        display: block;
        color: #ddd;
        padding: 15px 20px;
        text-decoration: none;
        transition: 0.3s;
        font-size: 16px;
        }

        .menu a:hover {
        background: #198754;
        color: white;
        padding-left: 25px;
        }

        .menu .active {
        background: #198754;
        color: white !important;
        padding-left: 25px;
        }

        .menu i {
        margin-right: 10px;
        }

        /* CONTENIDO */

        .content {
        flex: 1;
        padding: 20px;
        }

        /* NAVBAR */

        .topbar {
        background: white;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0px 2px 5px rgba(0,0,0,0.1);
        }

    </style>

</head>

<body>

    <div class="wrapper">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <div class="logo">

                <i class="bi bi-building"></i>

                Mi Hotel

            </div>

            <div class="menu">

                <a asp-controller="Habitaciones"
                       asp-action="Index"
                       class="@(currentController == "Habitaciones" ? "active" : "")">

                    <i class="bi bi-house-door-fill"></i>

                    Habitaciones

                </a>

                <a asp-controller="Historial"
                       asp-action="Index"
                       class="@(currentController == "Historial" ? "active" : "")">

                    <i class="bi bi-clock-history"></i>

                    Historial

                </a>

                <a asp-controller="ServicioCuarto"
                       asp-action="Index"
                       class="@(currentController == "ServicioCuarto" ? "active" : "")">

                    <i class="bi bi-cup-hot-fill"></i>

                    Servicio al Cuarto

                </a>

                <li>

                    <a asp-controller="Pagos"
                           asp-action="Index">

                        <i class="bi bi-cash-stack"></i>

                        Pagos

                    </a>

                </li>

                <a asp-controller="Login"
                       asp-action="Logout">

                    <i class="bi bi-box-arrow-right"></i>

                    Salir

                </a>

            </div>

        </div>

        <!-- CONTENIDO -->

        <div class="content">

            <!-- TOPBAR -->

            <div class="topbar d-flex justify-content-between">

                <h4>
                    Sistema Hotelero
                </h4>

                <div>

                    <i class="bi bi-person-circle"></i>

                    Administrador

                </div>

            </div>

            <!-- CONTENIDO DINAMICO -->
            @RenderBody()

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>