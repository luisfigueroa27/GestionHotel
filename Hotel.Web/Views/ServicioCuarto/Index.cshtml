@model IEnumerable<Hotel.Domain.Entities.ServicioCuarto>

@{
    ViewData["Title"] = "Servicio al Cuarto";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid">

    <div class="row">

        <!-- FORMULARIO -->

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-header bg-dark text-white">

                    <h5>Registrar Servicio</h5>

                </div>

                <div class="card-body">

                    <form asp-action="Registrar"
                          method="post">

                        <div class="mb-3">

                            <label>Habitación</label>

                            <select name="IdHabitacion"
                                    class="form-select"
                                    required>

                                <option value="">
                                    Seleccione
                                </option>

                                @foreach (var h in ViewBag.Habitaciones)
                                {
                                    <option value="@h.IdHabitacion">

                                        @h.NumeroHabitacion

                                    </option>
                                }

                            </select>

                        </div>

                        <div class="mb-3">

                            <label>Descripción</label>

                            <textarea name="Descripcion"
                                      class="form-control"
                                      rows="4"
                                      required></textarea>

                        </div>

                        <button type="submit"
                                class="btn btn-success w-100">

                            Registrar Servicio

                        </button>

                    </form>

                </div>

            </div>

        </div>

        <!-- TABLA -->

        <div class="col-md-8">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h5>Servicios Registrados</h5>

                </div>

                <div class="card-body">

                    <table class="table table-bordered table-hover">

                        <thead class="table-dark">

                            <tr>

                                <th>Habitación</th>

                                <th>Descripción</th>

                                <th>Fecha</th>

                                <th>Estado</th>

                                <th width="150">Acciones</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.Habitacion?.NumeroHabitacion
                                    </td>

                                    <td>
                                        @item.Descripcion
                                    </td>

                                    <td>
                                        @item.FechaSolicitud
                                    </td>

                                    <td>

                                        @if (item.Estado == "Pendiente")
                                        {
                                            <span class="badge bg-warning text-dark">

                                                Pendiente

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">

                                                Completado

                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (item.Estado == "Pendiente")
                                        {
                                            <form asp-action="Completar"
                                                  method="post">

                                                <input type="hidden"
                                                       name="id"
                                                       value="@item.IdServicio" />

                                                <button type="submit"
                                                        class="btn btn-success btn-sm">

                                                    Completar

                                                </button>

                                            </form>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

@if (TempData["success"] != null)
{
    <script>

        Swal.fire({
        icon:'success',
        title:'Éxito',
        text:'@TempData["success"]'
        });

    </script>
}
