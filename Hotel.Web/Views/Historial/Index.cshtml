@model IEnumerable<Hotel.Domain.Entities.Hospedaje>

@{
    ViewData["Title"] = "Historial";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-4">

    <div class="mb-4">

        <h2>Historial de Hospedajes</h2>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>

                        <th>Habitación</th>

                        <th>Huésped</th>

                        <th>DNI</th>

                        <th>Fecha Entrada</th>

                        <th>Fecha Salida</th>

                        <th>Estado</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Habitacion?.NumeroHabitacion
                            </td>

                            <td>
                                @item.Huesped?.NombreCompleto
                            </td>

                            <td>
                                @item.Huesped?.DNI
                            </td>

                            <td>
                                @item.FechaEntrada.ToShortDateString()
                            </td>

                            <td>
                                @item.FechaSalida.ToShortDateString()
                            </td>

                            <td>

                                @if (item.Estado == "Activo")
                                {
                                    <span class="badge bg-success">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Finalizado
                                    </span>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@if (TempData["success"] != null)
{
    <script>

        Swal.fire({
        icon:'success',
        title:'Éxito',
        text:'@TempData["success"]'
        });

    </script>
}